# justask - Configuration Template
# setup.sh copies this file to config.env and fills in the generated secrets.
# After setup: edit config.env directly to enable notifications, change branding, etc.
# config.env is excluded from git!

# -------------------------------------------------------------------
# Security
# -------------------------------------------------------------------

# Flask secret key for session signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# bcrypt hash for the staff (Mitarbeiter) shared password.
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
STAFF_PASSWORD_HASH=

# bcrypt hash for the admin shared password.
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# -------------------------------------------------------------------
# Notifications (both optional, independent of each other)
# -------------------------------------------------------------------

# --- E-mail notifications ---

# Recipient address for new feedback alerts (leave empty to disable).
# Example: feedback-team@firma.de
NOTIFICATION_EMAIL=

# SMTP server settings for sending mail.
# Example (Office 365): SMTP_HOST=smtp.office365.com  SMTP_PORT=587
# Example (Gmail):      SMTP_HOST=smtp.gmail.com      SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Sender address shown in the email From header.
# Defaults to SMTP_USER if empty.
# Example: noreply@firma.de
SMTP_FROM=

# --- Webhook notifications ---

# Webhook URL for chat notifications (leave empty to disable).
# Works with Slack, Rocket.Chat, Mattermost (incoming webhook).
# Example: https://chat.firma.de/hooks/xxx
NOTIFICATION_WEBHOOK_URL=

# Auth token for the webhook (leave empty if not required).
# Rocket.Chat: shown when creating an incoming webhook.
NOTIFICATION_WEBHOOK_TOKEN=

# -------------------------------------------------------------------
# Base URL (used for QR code generation)
# -------------------------------------------------------------------

# Full URL without trailing slash.
# Example: https://feedback.example.com
BASE_URL=

# -------------------------------------------------------------------
# Localisation
# -------------------------------------------------------------------

# Default language shown to customers. Options: de, en
DEFAULT_LANGUAGE=de

# -------------------------------------------------------------------
# Validation
# -------------------------------------------------------------------

# Regex pattern that offer numbers must match.
# Default expects format "123/25" (three digits, slash, two digits).
OFFER_NUMBER_PATTERN=^\d{3}/\d{2}$

# Regex pattern that project numbers must match (optional field).
# Defaults to OFFER_NUMBER_PATTERN if empty.
PROJECT_NUMBER_PATTERN=

# -------------------------------------------------------------------
# Session
# -------------------------------------------------------------------

# How long a staff/admin session stays valid (in minutes).
SESSION_LIFETIME_MINUTES=30

# -------------------------------------------------------------------
# Branding
# -------------------------------------------------------------------

BRANDING_COMPANY_NAME=justask
BRANDING_LOGO=/static/img/logo.png
BRANDING_PRIMARY_COLOR=#354660
BRANDING_SECONDARY_COLOR=#f26d40
